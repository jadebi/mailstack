# Cloudflared Tunnel - Production Configuration
# Copy this file to .env.tunnel and fill in your values.
# Command: cp .env.tunnel.example .env.tunnel
# For standard Zero Trust remote-managed deployments, only TUNNEL_TOKEN is strictly required.
# All you really need to start is the TUNNEL_TOKEN

# =============================================================================
# Authentication (required for named tunnels)
# =============================================================================

# The 64+ character cryptographic token that connects your container to your 
# Cloudflare Zero Trust dashboard account.
# Obtain this from the Zero Trust Dashboard -> Networks -> Tunnels -> Connectors.
TUNNEL_TOKEN=your-ey-token-string-here

# =============================================================================
# Transport & Networking
# =============================================================================

# Tells the container how to communicate with the Cloudflare edge routing nodes.
# Accepted values: auto, quic, http2, h2mux (legacy)
# Default: auto (Will attempt QUIC, and fallback to HTTP/2 if UDP is blocked)
# TUNNEL_TRANSPORT_PROTOCOL=auto

# Restricts the container's outbound network connection rules to the edge.
# Accepted values: auto, 4 (IPv4 only), 6 (IPv6 only)
# Default: auto
# TUNNEL_EDGE_IP_VERSION=auto

# Maximum number of retries for connection/protocol errors.
# Default: 5
# TUNNEL_RETRIES=5

# Maximum ping frequency in seconds to check the connection to the edge.
# Default: 15s
# TUNNEL_PING_FREQ=15s

# =============================================================================
# Logging & Diagnostics
# =============================================================================

# ---------------------------------------------------------------------------
# Output parameters
# ---------------------------------------------------------------------------

# Alters the verbosity of the internal cloudflared logs.
# Accepted values: debug, info, warn, error, fatal
# Default: info
# TUNNEL_LOGLEVEL=info

# Routes the internal output directly into a standard text logging path instead 
# of the general Docker stdout. 
# TUNNEL_LOGFILE=/var/log/cloudflared.log

# Directory to save logs. Useful if you want to mount a persistent volume 
# for logs instead of specifying a single file.
# TUNNEL_LOG_DIRECTORY=/var/log/cloudflared/

# =============================================================================
# Metrics & Monitoring
# =============================================================================

# Exposes a local Prometheus scraping socket endpoint (e.g., localhost:2000) 
# to check tunnel health data, connections, and request metrics locally.
# Example: 0.0.0.0:2000
# TUNNEL_METRICS=0.0.0.0:2000

# =============================================================================
# Local Origin Configuration (Locally-Managed / Quick Tunnels)
# =============================================================================

# Note: If you are using Dashboard-managed Tunnels (Zero Trust), you should 
# configure these settings directly in the Cloudflare Dashboard instead of here.
# These variables are primarily for local config.yml or quick CLI runs.

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------

# The local URL your tunnel should proxy traffic to (e.g., http://localhost:8080)
# TUNNEL_URL=http://localhost:8080

# The hostname to use for the tunnel (requires an origin certificate).
# TUNNEL_HOSTNAME=tunnel.yourdomain.com

# ---------------------------------------------------------------------------
# TLS & HTTP Headers
# ---------------------------------------------------------------------------

# Disables TLS verification of the certificate presented by your local service.
# Useful if your local origin uses self-signed certificates.
# Default: false
# TUNNEL_NO_TLS_VERIFY=true

# Sets the HTTP Host header sent to your local origin service.
# Useful if your local web server requires a specific hostname to route traffic.
# TUNNEL_HTTP_HOST_HEADER=localhost

# Sets the Server Name Indication (SNI) for TLS connections to the origin.
# TUNNEL_ORIGIN_SERVER_NAME=localhost

# =============================================================================
# Graceful Shutdown
# =============================================================================

# When the container is stopped, how long should it wait to finish actively 
# processing connections before force-closing.
# Default: 30s
# TUNNEL_GRACE_PERIOD=30s